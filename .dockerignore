# Keep the build context small and the image clean.

# Python caches / build artifacts
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.mypy_cache/
.ruff_cache/

# Virtual environments (the image builds its own)
.venv/
venv/
env/

# Local outputs and logs (mounted at runtime, not baked in)
out/
medias/

# Large sample media — not needed inside the image
samples/*.mp3

# Notebooks and their checkpoints
notebooks/
.ipynb_checkpoints/

# VCS / editor / OS noise
.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Docker files themselves
Dockerfile*
docker-compose.yml
.dockerignore
