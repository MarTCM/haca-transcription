# syntax=docker/dockerfile:1
# GPU image for the batch transcription CLI.
#
# Why a CUDA+cuDNN base: faster-whisper runs on CTranslate2, which dynamically
# loads cuBLAS and cuDNN at runtime. The "-cudnn-" runtime image ships both, which
# avoids the most common "cannot load libcudnn/libcublas" startup error.
#
# Build:
#   docker build -f transcription/Dockerfile.gpu -t haca-transcribe:gpu transcription/
#
# Run (see docs/CLI_ARCHITECTURE.md §11 for full examples):
#   docker run --rm --gpus all \
#     -v /data/medias:/data/medias:ro -v /data/out:/app/out \
#     -v haca-model-cache:/cache/huggingface -e HF_TOKEN=hf_xxx \
#     haca-transcribe:gpu --medias /data/medias --channel al-oula --year 2024 --month 6
#
# Host prerequisites: NVIDIA driver + NVIDIA Container Toolkit (for --gpus all).
# Match the torch CUDA wheel (cu124) and the base image CUDA (12.4) to a driver
# that supports them.

FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    # Persist downloaded models here; mount a volume at this path to keep them
    # across container runs (large-v3 / turbo / LoRA / pyannote are multi-GB).
    HF_HOME=/cache/huggingface

# python3, pip, git (some HF model fetches need it), ffmpeg (broad media decoding).
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        git \
        ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies first for better layer caching.
# IMPORTANT: install the CUDA-matched torch FIRST. transformers/peft/accelerate
# all declare a `torch` dependency, so if requirements.txt is installed first pip
# pulls the generic PyPI torch (~530 MB) + triton (~200 MB) only to have it
# replaced by the cu124 build below -- torch ends up downloaded twice. Installing
# the cu124 torch first satisfies that dependency so requirements never fetch the
# PyPI build. torchaudio is included because WhisperX needs it and must match
# torch's CUDA.
#
# FLAKY/SLOW NETWORKS: the cu124 torch stack is ~2.5 GB across several large
# wheels (torch ~768 MB, nvidia-cusparse ~207 MB, nvidia-cusolver ~128 MB, ...),
# and a single stalled read aborts the whole step. To make builds *resumable*:
#   1. A BuildKit pip cache mount persists already-downloaded wheels across build
#      attempts, so a re-run continues from where it timed out instead of
#      restarting the multi-GB download. (This is why we do NOT use
#      --no-cache-dir here -- it would defeat the cache.)
#   2. Each install is its own layer, so once a layer completes Docker caches it
#      and never re-runs it.
#   3. --timeout 1000 / --retries 10 tolerate long stalls.
# If a build still times out, simply re-run `docker build` -- it will pick up the
# cached wheels and make forward progress each time.
# - torch/torchaudio (CUDA 12.4): WhisperX, the LoRA, and the --device auto probe
# - requirements.txt:             faster-whisper + transformers + peft (Darija LoRA)
# - requirements_whisperx.txt:    whisperx + pyannote (only used by --speaker-annotation)
COPY requirements.txt requirements_whisperx.txt ./
RUN --mount=type=cache,target=/root/.cache/pip \
    pip3 install --retries 10 --timeout 1000 \
        torch torchaudio --index-url https://download.pytorch.org/whl/cu124
RUN --mount=type=cache,target=/root/.cache/pip \
    pip3 install --retries 10 --timeout 1000 -r requirements.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    pip3 install --retries 10 --timeout 1000 -r requirements_whisperx.txt

# Copy the project (core/, cli.py, src/, ...). See .dockerignore for exclusions.
COPY . .

# Default output + log dirs (usually overridden by a bind-mount on /app/out).
RUN mkdir -p /app/out/srt /app/out/logs /cache/huggingface

# The CLI is the entrypoint: everything after the image name is a CLI flag.
ENTRYPOINT ["python3", "cli.py"]
# Show help when run with no arguments.
CMD ["--help"]
